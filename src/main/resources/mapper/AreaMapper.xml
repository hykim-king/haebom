<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pcwk.ehr.area.AreaMapper">

    <!-- 시도 목록 조회 -->
    <select id="getCtpvList" resultType="AreaVO">
        SELECT DISTINCT
            TRIP_CTPV,
            TRIP_CTPV_NM
        FROM AREA
        ORDER BY TRIP_CTPV
    </select>

    <!-- 특정 시도의 군구 목록 조회 -->
    <select id="getGnguList" parameterType="AreaVO" resultType="AreaVO">
        SELECT
            AREA_NO,
            TRIP_CTPV,
            TRIP_CTPV_NM,
            TRIP_GUNGU,
            TRIP_GUNGU_NM
        FROM AREA
        WHERE TRIP_CTPV = #{tripCtpv}
        ORDER BY TRIP_GUNGU
    </select>

    <!-- 전체 조회 -->
    <select id="getAll" resultType="AreaVO">
        SELECT * FROM AREA
    </select>

    <!-- 건수 조회 -->
    <select id="getCount" resultType="int">
        SELECT COUNT(*) FROM AREA
    </select>

</mapper>
