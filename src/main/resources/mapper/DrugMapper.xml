<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pcwk.ehr.drug.DrugMapper">

    <!-- 약국 등록 -->
    <insert id="doSave" parameterType="DrugVO">
        INSERT INTO drug (
            DS_NO,
            DS_NM,
            DS_ADDR,
            DS_TELNO,
            DS_LAT,
            DS_LOT,
            DS_OP_TM,
            DS_END_TM,
            DS_WKND_OPEN_YN
        ) VALUES (
            #{dsNo},
            #{dsNm},
            #{dsAddr},
            #{dsTelno},
            #{dsLat},
            #{dsLot},
            #{dsOpTm},
            #{dsEndTm},
            #{dsWkndOpenYn}
        )
    </insert>

    <!-- 약국 삭제 -->
    <delete id="doDelete" parameterType="DrugVO">
        DELETE FROM drug
        WHERE DS_NO = #{dsNo}
    </delete>

    <!-- 전체 삭제 -->
    <delete id="deleteAll">
        DELETE FROM drug
    </delete>

    <!-- 건수 조회 -->
    <select id="getCount" resultType="int">
        SELECT COUNT(*) FROM drug
    </select>

    <!-- 단건 조회 -->
    <select id="doSelectOne" parameterType="DrugVO" resultType="DrugVO">
        SELECT
            DS_NO,
            DS_NM,
            DS_ADDR,
            DS_TELNO,
            DS_LAT,
            DS_LOT,
            DS_OP_TM,
            DS_END_TM,
            DS_WKND_OPEN_YN
        FROM drug
        WHERE DS_NO = #{dsNo}
    </select>

    <!-- 전체 조회 -->
    <select id="getAll" resultType="DrugVO">
        SELECT
            DS_NO, DS_NM, DS_ADDR, DS_TELNO,
            DS_LAT, DS_LOT, DS_OP_TM, DS_END_TM,
            DS_WKND_OPEN_YN
        FROM drug
        ORDER BY DS_NO ASC
    </select>

    <!-- 공통 검색 조건 -->
    <sql id="searchCondition">
        <if test="searchWord != null and searchWord != ''">
            AND (DS_NM LIKE '%' || #{searchWord} || '%' OR DS_ADDR LIKE '%' || #{searchWord} || '%')
        </if>
        <if test="region != null and region != '' and region != '전체'">
            <choose>
                <when test="region == '충북'">AND DS_ADDR LIKE '%충청북도%'</when>
                <when test="region == '충남'">AND DS_ADDR LIKE '%충청남도%'</when>
                <when test="region == '전북'">AND DS_ADDR LIKE '%전라북도%'</when>
                <when test="region == '전남'">AND DS_ADDR LIKE '%전라남도%'</when>
                <when test="region == '경북'">AND DS_ADDR LIKE '%경상북도%'</when>
                <when test="region == '경남'">AND DS_ADDR LIKE '%경상남도%'</when>
                <otherwise>AND DS_ADDR LIKE '%' || #{region} || '%'</otherwise>
            </choose>
        </if>
    </sql>

    <!-- 목록 조회 (페이징 + totalCnt) -->
    <select id="doRetrieve" parameterType="DrugVO" resultType="DrugVO">
        SELECT A.*, B.TOTAL_CNT AS totalCnt
        FROM (
            SELECT TT1.*
            FROM (
                SELECT ROWNUM AS rnum, T1.*
                FROM (
                    SELECT
                        DS_NO,
                        DS_NM,
                        DS_ADDR,
                        DS_TELNO,
                        DS_LAT,
                        DS_LOT,
                        DS_OP_TM,
                        DS_END_TM,
                        DS_WKND_OPEN_YN
                    FROM drug
                    WHERE 1 = 1
                    <include refid="searchCondition"/>
                    ORDER BY DS_NO ASC
                ) T1
                <![CDATA[WHERE ROWNUM <= #{pageSize} * (#{pageNo} - 1) + #{pageSize}]]>
            ) TT1
            <![CDATA[WHERE rnum >= #{pageSize} * (#{pageNo} - 1) + 1]]>
        ) A CROSS JOIN (
            SELECT COUNT(*) TOTAL_CNT
            FROM drug
            WHERE 1 = 1
            <include refid="searchCondition"/>
        ) B
    </select>

</mapper>
