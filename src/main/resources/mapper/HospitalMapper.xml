<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pcwk.ehr.hospital.HospitalMapper">

    <!-- 병원 등록 -->
    <insert id="doSave" parameterType="HospitalVO">
        INSERT INTO hospital (
            HP_NO,
            HP_NM,
            HP_ADDR,
            HP_EMRM_YN,
            HP_TELNO1,
            HP_TELNO2,
            HP_LAT,
            HP_LOT,
            HP_OP_TM,
            HP_END_TM,
            HP_WKND_OPEN_YN
        ) VALUES (
            #{hpNo},
            #{hpNm},
            #{hpAddr},
            #{hpEmrmYn},
            #{hpTelno1},
            #{hpTelno2},
            #{hpLat},
            #{hpLot},
            #{hpOpTm},
            #{hpEndTm},
            #{hpWkndOpenYn}
        )
    </insert>

    <!-- 병원 삭제 -->
    <delete id="doDelete" parameterType="HospitalVO">
        DELETE FROM hospital
        WHERE HP_NO = #{hpNo}
    </delete>

    <!-- 전체 삭제 -->
    <delete id="deleteAll">
        DELETE FROM hospital
    </delete>

    <!-- 건수 조회 -->
    <select id="getCount" resultType="int">
        SELECT COUNT(*) FROM hospital
    </select>

    <!-- 단건 조회 -->
    <select id="doSelectOne" parameterType="HospitalVO" resultType="HospitalVO">
        SELECT
            HP_NO,
            HP_NM,
            HP_ADDR,
            HP_EMRM_YN,
            HP_TELNO1,
            HP_TELNO2,
            HP_LAT,
            HP_LOT,
            HP_OP_TM,
            HP_END_TM,
            HP_WKND_OPEN_YN
        FROM hospital
        WHERE HP_NO = #{hpNo}
    </select>

    <!-- 전체 조회 -->
    <select id="getAll" resultType="HospitalVO">
        SELECT
            HP_NO, HP_NM, HP_ADDR, HP_EMRM_YN,
            HP_TELNO1, HP_TELNO2, HP_LAT, HP_LOT,
            HP_OP_TM, HP_END_TM, HP_WKND_OPEN_YN
        FROM hospital
        ORDER BY HP_NO ASC
    </select>

    <!-- 공통 검색 조건 -->
    <sql id="searchCondition">
        <if test="searchWord != null and searchWord != ''">
            AND (HP_NM LIKE '%' || #{searchWord} || '%' OR HP_ADDR LIKE '%' || #{searchWord} || '%')
        </if>
        <if test="region != null and region != '' and region != '전체'">
            <choose>
                <when test="region == '충북'">AND HP_ADDR LIKE '%충청북도%'</when>
                <when test="region == '충남'">AND HP_ADDR LIKE '%충청남도%'</when>
                <when test="region == '전북'">AND HP_ADDR LIKE '%전라북도%'</when>
                <when test="region == '전남'">AND HP_ADDR LIKE '%전라남도%'</when>
                <when test="region == '경북'">AND HP_ADDR LIKE '%경상북도%'</when>
                <when test="region == '경남'">AND HP_ADDR LIKE '%경상남도%'</when>
                <otherwise>AND HP_ADDR LIKE '%' || #{region} || '%'</otherwise>
            </choose>
        </if>
    </sql>

    <!-- 목록 조회 (페이징 + totalCnt) -->
    <select id="doRetrieve" parameterType="HospitalVO" resultType="HospitalVO">
        SELECT A.*, B.TOTAL_CNT AS totalCnt
        FROM (
            SELECT TT1.*
            FROM (
                SELECT ROWNUM AS rnum, T1.*
                FROM (
                    SELECT
                        HP_NO,
                        HP_NM,
                        HP_ADDR,
                        HP_EMRM_YN,
                        HP_TELNO1,
                        HP_TELNO2,
                        HP_LAT,
                        HP_LOT,
                        HP_OP_TM,
                        HP_END_TM,
                        HP_WKND_OPEN_YN
                    FROM hospital
                    WHERE 1 = 1
                    <include refid="searchCondition"/>
                    ORDER BY HP_NO ASC
                ) T1
                <![CDATA[WHERE ROWNUM <= #{pageSize} * (#{pageNo} - 1) + #{pageSize}]]>
            ) TT1
            <![CDATA[WHERE rnum >= #{pageSize} * (#{pageNo} - 1) + 1]]>
        ) A CROSS JOIN (
            SELECT COUNT(*) TOTAL_CNT
            FROM hospital
            WHERE 1 = 1
            <include refid="searchCondition"/>
        ) B
    </select>

</mapper>
