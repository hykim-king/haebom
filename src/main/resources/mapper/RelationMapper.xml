<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.pcwk.ehr.relation.RelationMapper">

    <!-- 단건 조회 -->
    <select id="doSelectOne" parameterType="RelationVO" resultType="RelationVO">
        SELECT REL_NO,
               REL_CLSF,
               USER_NO,
               COURSE_NO,
               TRIP_CONTS_ID
        FROM RELATION
        WHERE REL_NO = #{relNo}
    </select>

    <!-- 사용자별 관계 목록 조회 (찜/완료 분류 포함) -->
    <select id="getListByUser" parameterType="RelationVO" resultType="RelationVO">
        SELECT REL_NO,
               REL_CLSF,
               USER_NO,
               COURSE_NO,
               TRIP_CONTS_ID
        FROM RELATION
        WHERE USER_NO = #{userNo}
        <if test="relClsf != 0">
            AND REL_CLSF = #{relClsf}
        </if>
        ORDER BY REL_NO DESC
    </select>

    <!-- 등록 -->
    <insert id="doSave" parameterType="RelationVO">
        INSERT INTO RELATION (
            REL_NO,
            REL_CLSF,
            USER_NO,
            COURSE_NO,
            TRIP_CONTS_ID
        ) VALUES (
            SEQ_REL_NO.NEXTVAL,
            #{relClsf},
            #{userNo},
            #{courseNo},
            #{tripContsId}
        )
    </insert>

    <!-- 수정 -->
    <update id="doUpdate" parameterType="RelationVO">
        UPDATE RELATION
        SET REL_CLSF     = #{relClsf},
            COURSE_NO    = #{courseNo},
            TRIP_CONTS_ID = #{tripContsId}
        WHERE REL_NO = #{relNo}
    </update>

    <!-- 삭제 -->
    <delete id="doDelete" parameterType="RelationVO">
        DELETE
        FROM RELATION
        WHERE REL_NO = #{relNo}
    </delete>

    <!-- 전체 조회 -->
    <select id="getAll" resultType="RelationVO">
        SELECT *
        FROM RELATION
    </select>

    <!-- 전체 건수 -->
    <select id="getCount" resultType="Int">
        SELECT COUNT(*)
        FROM RELATION
    </select>

    <!-- 전체 삭제 (테스트용) -->
    <delete id="deleteAll">
        DELETE
        FROM RELATION
    </delete>

</mapper>
